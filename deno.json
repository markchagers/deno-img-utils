{
    "name": "Test project",
    "tasks": {
        "start": "deno run --allow-env --allow-ffi --allow-read --watch main.ts",
        "test": "deno test --allow-env --allow-ffi --allow-read",
        "lint": "deno lint",
        "icvrt": "deno run --allow-env --allow-ffi --allow-read --allow-write main.ts"
    },
    "imports": {
        "assert": "jsr:@std/assert@^1.0.0",
        "chalk": "npm:chalk@5",
        "sharp": "npm:sharp@^0.34.5",
        "bdd": "jsr:@std/testing/bdd",
        "expect": "jsr:@std/expect",
        "base64": "jsr:@std/encoding/base64"
    },
    "fmt": {
        "indentWidth": 4,
        "lineWidth": 100,
        "semiColons": true,
        "singleQuote": true
    },
    "exports": "./main.ts"
}
